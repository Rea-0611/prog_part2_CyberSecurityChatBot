<Window x:Class="prog_part2_CyberSecurityChatBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Chatbot" 
        Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="550" MinWidth="750">

    <Window.Resources>
        <!-- Background Gradient -->
        <LinearGradientBrush x:Key="WindowBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1a1a2e" Offset="0"/>
            <GradientStop Color="#16213e" Offset="0.5"/>
            <GradientStop Color="#0f3460" Offset="1"/>
        </LinearGradientBrush>

        <!-- Header Gradient -->
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#0f3460" Offset="0"/>
            <GradientStop Color="#16213e" Offset="0.5"/>
            <GradientStop Color="#0f3460" Offset="1"/>
        </LinearGradientBrush>

        <!-- Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#00b4d8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="25"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0096c7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0077b6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2d2d44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CaretBrush" Value="#00b4d8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="10"
                                BorderThickness="0">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBackground}">

       
        <!-- PAGE 1: HOME / START PAGE -->
        
        <Grid x:Name="home_grid" Visibility="Visible">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <!-- Logo Image -->
                <Border CornerRadius="60" Width="120" Height="120" 
                        Background="#00b4d8" Margin="0,0,0,20">
                    <Image Source="/image.jpg" Width="100" Height="100" 
                           Stretch="UniformToFill">
                        <Image.Clip>
                            <EllipseGeometry Center="50,50" RadiusX="50" RadiusY="50"/>
                        </Image.Clip>
                    </Image>
                </Border>

                <!-- Title -->
                <TextBlock Text="🛡️ CYBER SECURITY" 
                           FontSize="32" FontWeight="Bold" 
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="AWARENESS CHATBOT" 
                           FontSize="32" FontWeight="Bold" 
                           Foreground="#00b4d8"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <!-- Decorative line -->
                <Border Height="2" Width="200" Background="#00b4d8" 
                        Margin="0,15,0,15" CornerRadius="1"/>

                <!-- Tagline -->
                <TextBlock Text="Your Personal Security Assistant" 
                           FontSize="14" 
                           Foreground="#cccccc"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,30"/>

                <!-- Start Button -->
                <Button x:Name="StartButton"
                        Content="🚀 START CHATBOT" 
                        Style="{StaticResource ModernButton}"
                        Click="welcome"
                        Width="250"
                        Height="50"/>

                <!-- Security Tips -->
                <TextBlock Text="🔐 Stay Safe Online  |  📧 Avoid Phishing  |  🔑 Strong Passwords" 
                           FontSize="11" 
                           Foreground="#888888"
                           HorizontalAlignment="Center"
                           Margin="0,40,0,0"/>
            </StackPanel>
        </Grid>

        
        <!-- PAGE 2: USERNAME INPUT PAGE -->
        
        <Grid x:Name="username_grid" Visibility="Hidden">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">

                <!-- Icon -->
                <TextBlock Text="👋" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <!-- Title -->
                <TextBlock Text="Welcome Aboard!" 
                           FontSize="28" FontWeight="Bold" 
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <!-- Subtitle -->
                <TextBlock Text="Let's get to know each other" 
                           FontSize="14" 
                           Foreground="#aaaaaa"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <!-- Name Input Label -->
                <TextBlock Text="What should I call you?" 
                           FontSize="14" 
                           Foreground="#cccccc"
                           Margin="0,0,0,8"/>

                <!-- Text Box -->
                <TextBox x:Name="usernames_input" 
                         Style="{StaticResource ModernTextBox}"
                         Margin="0,0,0,20"
                         KeyDown="UsernameTextBox_KeyDown"/>

                <!-- Error Message -->
                <TextBlock x:Name="error_message" 
                           Text="⚠️ Please enter a valid name" 
                           Foreground="#ff6b6b" 
                           FontSize="12"
                           Visibility="Collapsed"
                           Margin="0,0,0,10"/>

                <!-- Continue Button -->
                <Button x:Name="SubmitNameButton"
                        Content="CONTINUE →" 
                        Style="{StaticResource ModernButton}"
                        Click="submit_name"
                        Width="200"
                        HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        
        <!-- PAGE 3: CHAT PAGE -->
       
        <Grid x:Name="chat_grid" Visibility="Hidden">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource HeaderGradient}" 
                    Padding="15" CornerRadius="0,0,15,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo (small) -->
                    <Image Grid.Column="0" Source="/image.jpg" Width="40" Height="40" 
                           Stretch="UniformToFill" Margin="0,0,15,0">
                        <Image.Clip>
                            <EllipseGeometry Center="20,20" RadiusX="20" RadiusY="20"/>
                        </Image.Clip>
                    </Image>

                    <!-- Title -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="🛡️ CYBER SECURITY CHATBOT" 
                                   FontSize="16" FontWeight="Bold" 
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="user_greeting" 
                                   Text="" 
                                   FontSize="11" 
                                   Foreground="#00b4d8"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Status -->
                    <Border Grid.Column="2" Background="#00ff00" CornerRadius="8" 
                            Width="12" Height="12" Margin="10,0,0,0" VerticalAlignment="Center">
                        <Border.ToolTip>
                            <ToolTip Content="Bot is active"/>
                        </Border.ToolTip>
                    </Border>
                </Grid>
            </Border>

            <!-- Chat Display -->
            <ListView x:Name="chats" 
                      Grid.Row="1" 
                      Background="#0f0f1a" 
                      BorderThickness="0"
                      Margin="10"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="12" 
                                Margin="5,3" 
                                Padding="10,8" 
                                Background="{Binding Background}"
                                HorizontalAlignment="{Binding Alignment}"
                                MaxWidth="500">
                            <StackPanel>
                                <TextBlock Text="{Binding Sender}" 
                                           FontWeight="Bold" 
                                           FontSize="10"
                                           Foreground="#cccccc"
                                           Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding Message}" 
                                           TextWrapping="Wrap" 
                                           Foreground="White"
                                           FontSize="13"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Input Area -->
            <Border Grid.Row="2" Background="#1a1a2e" Padding="15" CornerRadius="15,15,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="question" 
                             Grid.Column="0" 
                             Style="{StaticResource ModernTextBox}"
                             KeyDown="Question_KeyDown"/>

                    <Button x:Name="SendButton"
                            Grid.Column="1" 
                            Content="✈️ SEND" 
                            Width="90" 
                            Margin="10,0,0,0"
                            Style="{StaticResource ModernButton}"
                            Click="send"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>       