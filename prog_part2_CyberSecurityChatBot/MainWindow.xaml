<Window x:Class="prog_part2_CyberSecurityChatBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🛡️ Cybersecurity Chatbot" 
        Height="700" 
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e"
        ResizeMode="CanResize"
        MinHeight="600" 
        MinWidth="800">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#00b4d8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="25" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0096c7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0077b6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2d2d44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CaretBrush" Value="#00b4d8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="10" 
                                BorderThickness="0">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#2d2d44"/>
            <Setter Property="Foreground" Value="#aaaaaa"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8,8,0,0"
                                Padding="{TemplateBinding Padding}" 
                                Margin="2,0">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#00b4d8"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3d3d5c"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChatItemStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border Background="{TemplateBinding Background}" 
                                BorderThickness="0" 
                                Padding="0" 
                                Margin="0">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TaskItemStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border Background="{TemplateBinding Background}" 
                                BorderThickness="0" 
                                Padding="0" 
                                Margin="0">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#1a1a2e">

        <Grid x:Name="home_grid" Visibility="Visible">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <Border CornerRadius="60" 
                        Width="120" 
                        Height="120" 
                        Background="#00b4d8" 
                        Margin="0,0,0,20">
                    <Image Source="/image.jpg" 
                           Width="100" 
                           Height="100" 
                           Stretch="UniformToFill">
                        <Image.Clip>
                            <EllipseGeometry Center="50,50" RadiusX="50" RadiusY="50"/>
                        </Image.Clip>
                    </Image>
                </Border>

                <TextBlock Text="🛡️ CYBER SECURITY" 
                           FontSize="32" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="AWARENESS CHATBOT" 
                           FontSize="32" 
                           FontWeight="Bold" 
                           Foreground="#00b4d8" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <Border Height="2" 
                        Width="200" 
                        Background="#00b4d8" 
                        Margin="0,15,0,15" 
                        CornerRadius="1"/>

                <TextBlock Text="Your Personal Security Assistant" 
                           FontSize="14" 
                           Foreground="#cccccc" 
                           HorizontalAlignment="Center" 
                           Margin="0,10,0,30"/>

                <Button x:Name="StartButton" 
                        Content="🚀 START CHATBOT" 
                        Style="{StaticResource ModernButton}" 
                        Click="welcome" 
                        Width="250" 
                        Height="50"/>

                <TextBlock Text="🔐 Stay Safe Online  |  📧 Avoid Phishing  |  🔑 Strong Passwords" 
                           FontSize="11" 
                           Foreground="#888888" 
                           HorizontalAlignment="Center" 
                           Margin="0,40,0,0"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="username_grid" Visibility="Hidden">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">

                <TextBlock Text="👋" 
                           FontSize="64" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,20"/>

                <TextBlock Text="Welcome Aboard!" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Let's get to know each other" 
                           FontSize="14" 
                           Foreground="#aaaaaa" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,30"/>

                <TextBlock Text="What should I call you?" 
                           FontSize="14" 
                           Foreground="#cccccc" 
                           Margin="0,0,0,8"/>

                <TextBox x:Name="usernames_input" 
                         Style="{StaticResource ModernTextBox}" 
                         Width="300"
                         Margin="0,0,0,20" 
                         KeyDown="UsernameTextBox_KeyDown"/>

                <TextBlock x:Name="error_message" 
                           Text="⚠️ Please enter a valid name" 
                           Foreground="#ff6b6b" 
                           FontSize="12" 
                           Visibility="Collapsed" 
                           Margin="0,0,0,10"/>

                <Button x:Name="SubmitNameButton" 
                        Content="CONTINUE →" 
                        Style="{StaticResource ModernButton}" 
                        Click="submit_name" 
                        Width="200" 
                        HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="chat_grid" Visibility="Hidden">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.RowSpan="1" Background="#0f3460" Padding="10" CornerRadius="0,0,10,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0" 
                           Source="/image.jpg" 
                           Width="40" 
                           Height="40" 
                           Stretch="UniformToFill" 
                           Margin="0,0,15,0">
                        <Image.Clip>
                            <EllipseGeometry Center="20,20" RadiusX="20" RadiusY="20"/>
                        </Image.Clip>
                    </Image>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="🛡️ CYBER SECURITY CHATBOT" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="White" 
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="user_greeting" 
                                   Text="" 
                                   FontSize="11" 
                                   Foreground="#00b4d8" 
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Column="2" 
                            Background="#00ff00" 
                            CornerRadius="8" 
                            Width="12" 
                            Height="12" 
                            Margin="10,0,0,0" 
                            VerticalAlignment="Center">
                        <Border.ToolTip>
                            <ToolTip Content="Bot is active"/>
                        </Border.ToolTip>
                    </Border>
                </Grid>
            </Border>

            <TabControl x:Name="MainTabControl" 
                        Grid.Row="1" 
                        Margin="10" 
                        Background="Transparent" 
                        BorderThickness="0"
                        SelectionChanged="TabControl_SelectionChanged">

                <TabItem Header="💬 Chat">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListView x:Name="chats" 
                                  Grid.Row="0" 
                                  Background="#0f0f1a" 
                                  BorderThickness="0"
                                  ItemContainerStyle="{StaticResource ChatItemStyle}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12" 
                                            Margin="5,3" 
                                            Padding="10,8" 
                                            Background="{Binding Background}"
                                            HorizontalAlignment="{Binding Alignment}"
                                            MaxWidth="500">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Sender}" 
                                                       FontWeight="Bold" 
                                                       FontSize="10"
                                                       Foreground="#cccccc"
                                                       Margin="0,0,0,3"/>
                                            <TextBlock Text="{Binding Message}" 
                                                       TextWrapping="Wrap" 
                                                       Foreground="White"
                                                       FontSize="13"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Border Grid.Row="1" 
                                Background="#1a1a2e" 
                                Padding="10" 
                                CornerRadius="10,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="question" 
                                         Grid.Column="0" 
                                         Style="{StaticResource ModernTextBox}" 
                                         KeyDown="Question_KeyDown"/>

                                <Button Grid.Column="1" 
                                        Content="✈️ SEND" 
                                        Width="80" 
                                        Margin="10,0,0,0" 
                                        Style="{StaticResource ModernButton}" 
                                        Click="send"/>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="📋 Tasks">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" 
                                Background="#2d2d44" 
                                CornerRadius="10" 
                                Padding="10" 
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="TaskTitleInput" 
                                         Grid.Column="0" 
                                         Text="Enter task title..." 
                                         Foreground="#888888"
                                         Background="#1a1a2e"
                                         BorderThickness="1"
                                         BorderBrush="#444444"
                                         Padding="10"
                                         GotFocus="TaskTitleInput_GotFocus"
                                         LostFocus="TaskTitleInput_LostFocus"/>

                                <Button Grid.Column="1"
                                        Content="➕ Add"
                                        Background="#00b4d8"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        Padding="15,10"
                                        Margin="10,0,0,0"
                                        Click="AddTaskButton_Click"/>
                            </Grid>
                        </Border>

                        <ListView x:Name="TaskListView" 
                                  Grid.Row="1" 
                                  Background="#0f0f1a" 
                                  BorderThickness="0"
                                  ItemContainerStyle="{StaticResource TaskItemStyle}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" 
                                            Margin="5,3" 
                                            Padding="10,8" 
                                            Background="#2d2d44">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding title}" 
                                                           FontWeight="Bold" 
                                                           Foreground="White"
                                                           FontSize="14"/>
                                                <TextBlock Text="{Binding description}" 
                                                           Foreground="#aaaaaa"
                                                           FontSize="12"/>
                                                <TextBlock Text="{Binding reminder_date}" 
                                                           Foreground="#888888"
                                                           FontSize="10"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" 
                                                        Orientation="Horizontal" 
                                                        Margin="10,0,0,0">
                                                <Button Content="✅" 
                                                        Background="Transparent" 
                                                        Foreground="#4caf50"
                                                        FontSize="18"
                                                        Cursor="Hand"
                                                        Click="CompleteTask_Click"
                                                        Tag="{Binding id}"/>
                                                <Button Content="🗑️" 
                                                        Background="Transparent" 
                                                        Foreground="#ff6b6b"
                                                        FontSize="18"
                                                        Cursor="Hand"
                                                        Margin="5,0,0,0"
                                                        Click="DeleteTask_Click"
                                                        Tag="{Binding id}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <TextBlock x:Name="TaskStatus" 
                                   Grid.Row="2" 
                                   Foreground="#888888" 
                                   HorizontalAlignment="Center"
                                   FontSize="12"
                                   Margin="0,10,0,0"/>
                    </Grid>
                </TabItem>

                <TabItem Header="🎮 Quiz">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel VerticalAlignment="Center" 
                                    HorizontalAlignment="Center" 
                                    Width="500" 
                                    Margin="20">

                            <TextBlock x:Name="QuizTitle" 
                                       Text="🧠 Cybersecurity Quiz" 
                                       FontSize="24" 
                                       FontWeight="Bold" 
                                       Foreground="White" 
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,10"/>

                            <TextBlock x:Name="QuizSubtitle" 
                                       Text="Test your cybersecurity knowledge!" 
                                       FontSize="14" 
                                       Foreground="#aaaaaa" 
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,20"/>

                            <Border Background="#2d2d44" 
                                    CornerRadius="10" 
                                    Padding="15" 
                                    Margin="0,0,0,15"
                                    Width="450">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" 
                                               Text="📊 Score:" 
                                               Foreground="#aaaaaa"
                                               FontSize="12"/>
                                    <TextBlock Grid.Column="1" 
                                               x:Name="QuizScoreDisplay" 
                                               Text="0/0" 
                                               Foreground="#00b4d8"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" 
                                               x:Name="QuizProgressDisplay" 
                                               Text="Question 0 of 0" 
                                               Foreground="#aaaaaa"
                                               FontSize="12"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <Border Background="#2d2d44" 
                                    CornerRadius="10" 
                                    Padding="20" 
                                    Margin="0,0,0,20"
                                    Width="450">
                                <TextBlock x:Name="QuizQuestionText" 
                                           Text="Click 'Start Quiz' to begin!" 
                                           Foreground="White"
                                           FontSize="16"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <StackPanel x:Name="QuizOptionsPanel" 
                                        Margin="0,0,0,15" 
                                        Width="450">
                                <Button x:Name="QuizOption1" 
                                        Content="A) Option 1" 
                                        Background="#2d2d44" 
                                        Foreground="White"
                                        Margin="0,5,0,5"
                                        Padding="15,10"
                                        Click="QuizOption_Click"
                                        Tag="0"
                                        HorizontalAlignment="Stretch"/>
                                <Button x:Name="QuizOption2" 
                                        Content="B) Option 2" 
                                        Background="#2d2d44" 
                                        Foreground="White"
                                        Margin="0,5,0,5"
                                        Padding="15,10"
                                        Click="QuizOption_Click"
                                        Tag="1"
                                        HorizontalAlignment="Stretch"/>
                                <Button x:Name="QuizOption3" 
                                        Content="C) Option 3" 
                                        Background="#2d2d44" 
                                        Foreground="White"
                                        Margin="0,5,0,5"
                                        Padding="15,10"
                                        Click="QuizOption_Click"
                                        Tag="2"
                                        HorizontalAlignment="Stretch"/>
                                <Button x:Name="QuizOption4" 
                                        Content="D) Option 4" 
                                        Background="#2d2d44" 
                                        Foreground="White"
                                        Margin="0,5,0,5"
                                        Padding="15,10"
                                        Click="QuizOption_Click"
                                        Tag="3"
                                        HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <Border x:Name="QuizFeedbackBorder" 
                                    Background="#1a1a2e" 
                                    CornerRadius="10" 
                                    Padding="15" 
                                    Margin="0,0,0,15"
                                    Visibility="Collapsed"
                                    Width="450">
                                <TextBlock x:Name="QuizFeedback" 
                                           Text="" 
                                           Foreground="#4caf50"
                                           FontSize="14"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <Button x:Name="StartQuizButton" 
                                    Content="🚀 Start Quiz" 
                                    Background="#00b4d8" 
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Padding="30,12"
                                    Click="StartQuizButton_Click"
                                    Width="200"
                                    HorizontalAlignment="Center"/>

                            <Border Background="#2d2d44" 
                                    CornerRadius="10" 
                                    Padding="15" 
                                    Margin="0,20,0,0" 
                                    Width="450">
                                <StackPanel>
                                    <TextBlock Text="📜 Your Quiz History" 
                                               Foreground="White"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Margin="0,0,0,10"/>
                                    <TextBlock x:Name="QuizHistoryText" 
                                               Text="Complete a quiz to see your history!" 
                                               Foreground="#888888"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="📊 Activity Log">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" 
                                Background="#2d2d44" 
                                CornerRadius="10" 
                                Padding="15" 
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="📋 Recent Activity" 
                                               FontSize="16" 
                                               FontWeight="Bold" 
                                               Foreground="White"/>
                                    <TextBlock Text="All actions are logged to the database" 
                                               FontSize="11" 
                                               Foreground="#888888"/>
                                </StackPanel>

                                <Button Grid.Column="1" 
                                        Content="🔄 Refresh" 
                                        Background="#00b4d8" 
                                        Foreground="White"
                                        Padding="15,8"
                                        Click="RefreshLogButton_Click"/>
                            </Grid>
                        </Border>

                        <ListView x:Name="ActivityLogListView" 
                                  Grid.Row="1" 
                                  Background="#0f0f1a" 
                                  BorderThickness="0"
                                  ItemContainerStyle="{StaticResource TaskItemStyle}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" 
                                            Margin="5,3" 
                                            Padding="10,8" 
                                            Background="#2d2d44">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding timestamp}" 
                                                       Foreground="#888888"
                                                       FontSize="11"/>

                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding action}" 
                                                           FontWeight="Bold" 
                                                           Foreground="#00b4d8"
                                                           FontSize="13"/>
                                                <TextBlock Text="{Binding details}" 
                                                           Foreground="#aaaaaa"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>

    </Grid>
</Window>